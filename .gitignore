# Root gitignore
.vscode/
.DS_Store

# Python Virtual Environments (ทุกที่ในโปรเจค)
**/venv/
**/.venv/
**/env/

# Python Cache (ทุกที่)
**/__pycache__/
**/*.pyc

# ML Models & Data
**/models/
**/saved_models/
**/*.keras
**/*.h5
**/*.joblib

# Node.js (สำหรับ server/ และ client/)
node_modules/
.npm/

# Other services
backtest-service/venv/
python-grpc/venv/
ai-service/venv/
